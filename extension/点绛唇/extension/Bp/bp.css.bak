
.bpBg {
  /*背景图*/
  width: 100%;
  height: 100%;
  left: 0px;
  top: 0px;
  z-index: 8;
  background-image: url("./image/bpBg.png");
  background-size: 100% 100%;
}
.bpBg > .bpDialogHide {
  /*隐藏的背景（所有元素的父元素）*/
  top: 50%;
  left: 50%;
  height: 610px;
  width: 1200px;
  transform: translate(-50%, -50%);
}
.bpBg > .bpDialogHide > .bpJiangchiBg {
  /*将池底图*/
  background-image: url("./image/bpJiangchiBg.png");
  background-size: 100% 100%;
  top: 50%;
  left: 9%;
  height: 75%;
  width: 65%;
  transform: translateY(-50%);
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpBottom {
  /*下方按钮组*/
  bottom: 1.7%;
  height: 13%;
  width: 71.75%;
  left: 26%;
  overflow-y: hidden;
  overflow-x: auto;
  display: flex;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpBottom > .bpLbtn {
  /*每个按钮*/
  top: 5%;
  width: 30%;
  height: 80%;
  position: relative;
  display: block;
  background-image: url("./image/bpPlan.png");
  background-size: 100% 100%;
  color: #e3b88b;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpBottom > .bpLbtn:active {
  background-image: url("./image/bpPlanLight.png");
  color: #805c34;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpBottom > .bpLbtn > .bpLbtnText {
  /*每个按钮文字*/
  text-align: center;
  width: 100%;
  display: inline-block;
  font-family: "yuanli";
  font-size: 19px;
  transform: translate(-50%, -50%);
  top: 50%;
  left: 50%;
  font-weight: 550;
  text-shadow: none;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpCharacterPackLength {
  /*武将数*/
  top: 12%;
  left: 27%;
  font-size: 18px;
  color: #805c34;
  text-shadow: none;
  font-family: "yuanli";
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpClose {
  /*关闭按钮*/
  background-image: url("./image/bpClose.png");
  background-size: 100% 100%;
  top: 1%;
  right: 1%;
  width: 4.5%;
  height: 7%;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpSousuo {
  /*搜索按钮*/
  background-image: url("./image/bpSousuo.png");
  background-size: 100% 100%;
  top: 10%;
  right: 2.3%;
  width: 22%;
  height: 7%;
}
.bpSousuoInput {
  /*输入文本框*/
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1000;
  top: 5%;
  width: 60%;
  height: 10%;
  font-size: 30px;
  display: none;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpChoosePackBg {
  /*将池左侧选择武将包页面*/
  background-image: url("./image/bpChoosePackBg.png");
  background-size: 100% 100%;
  top: 9%;
  left: 0.3%;
  height: 89.2%;
  width: 25%;
  overflow-y: auto;
  overflow-x: hidden;
  display: block;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpChoosePackBg > .bpCharacterPack {
  /*武将包名称*/
  text-align: center;
  align-items: center;
  font-family: "yuanli";
  color: #805c34;
  position: relative;
  font-weight: 580;
  display: block;
  font-size: 19px;
  height: 9.41%;
  text-shadow: none;
  width: 100%;
  padding-top: 20px;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChoosePackBg
  > .bpCharacterPack::before {
  /*武将包名下划线*/
  content: "";
  background-image: url("./image/bpCharacterPackLine.png");
  line-height: 15;
  background-size: 100% 100%;
  width: 90%;
  height: 1px;
  position: absolute;
  bottom: 0;
  transform: translateX(-50%);
  left: 50%;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChoosePackBg
  > .bpCharacterPack.active {
  /*武将包点击效果*/
  background-image: url("./image/bpCharacterPack.png");
  background-size: 100% 100%;
  color: #805c34;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChoosePackBg
  > .bpCharacterPack.active::before {
  opacity: 0;
}
.bpBg > .bpDialogHide > .bpJiangchiBg > .bpChooseCharacterBg {
  /*武将总底图*/
  width: 71.75%;
  height: 67%;
  top: 18%;
  left: 26%;
  overflow-y: auto;
  overflow-x: hidden;
  display: block;
  background-color: rgb(0, 0, 0, 0.2);
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChooseCharacterBg
  > .bpCharacterBiankuang {
  /*单个武将的边框*/
  background-image: url("./image/bpCharacterBiankuang.png");
  background-size: 100% 100%;
  width: 85px;
  height: 85px;
  position: relative;
  margin-left: 6.7px; /* 改变left边距 */
  margin-top: 6.7px; /* 改变top边距 */
  margin-right: 0; /* right边距设置为0 */
  margin-bottom: 0; /* bottom边距设置为0 */
  overflow: hidden;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChooseCharacterBg
  > .bpCharacterBiankuang
  > .bpStart {
  /*星*/
  background-image: url("./image/bpStart.png");
  background-size: 0% 0%;
  width: 40px;
  height: 37px;
  right: -10%;
  bottom: -13%;
  z-index: 5;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChooseCharacterBg
  > .bpCharacterBiankuang
  > .bpStart
  > .startText {
  /*星数字*/
  color: #aa5417;
  font-size: 0px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-shadow: none;
  font-weight: 800;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChooseCharacterBg
  > .bpCharacterBiankuang
  > .bpActive {
  /*已禁*/
  background-image: url("./image/bpActive.png");
  background-size: 100% 100%;
  height: 100%;
  width: 100%;
  pointer-events: none;
  z-index: 4;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChooseCharacterBg
  > .bpCharacterBiankuang
  > .bpCharacterImage {
  /*武将图*/
  background-size: 100% 100%;
  height: 250%;
  width: 250%;
  top: 108%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: auto;
  cursor: pointer;
}
.bpBg
  > .bpDialogHide
  > .bpJiangchiBg
  > .bpChooseCharacterBg
  > .bpCharacterBiankuang
  > .bpCharacterName {
  /*武将名*/
  background-image: url("./image/bpCharacterName.png");
  background-size: 100% 100%;
  width: 20%;
  height: 95%;
  font-size: 13.5px;
  font-family: "yuanli";
}
.bpBg > .bpDialogHide > .bpPlansBg {
  /*方案底图*/
  background-image: url("./image/bpPlansBg.png");
  background-size: 100% 100%;
  top: 50%;
  right: 7%;
  height: 70%;
  width: 18%;
  transform: translateY(-50%);
}
.bpBg > .bpDialogHide > .bpPlansBg > .bpChangePlan {
  /*方案设置*/
  background-image: url("./image/bpChangePlan.png");
  background-size: 100% 100%;
  right: 12%;
  top: 3.5%;
  height: 35px;
  width: 35px;
}
.bpBg > .bpDialogHide > .bpPlansBg > .bpPlans {
  /*方案总背景*/
  top: 13%;
  left: 0;
  height: 75%;
  width: 93%;
  overflow-y: auto;
  overflow-x: hidden;
  display: block;
}
.bpBg > .bpDialogHide > .bpPlansBg > .bpPlans > .bpPlan {
  /* 每个方案按钮*/
  background-image: url("./image/bpPlan.png");
  background-size: 100% 100%;
  position: relative;
  display: flex;
  height: 15%;
  text-shadow: none;
  width: 75%;
  left: 50%;
  transform: translateX(-50%);
  margin-top: 15%;
  align-items: center;
  color: #e3b88b;
}
.bpBg > .bpDialogHide > .bpPlansBg > .bpPlans > .bpPlan.active {
  /*方案点击效果*/
  background-image: url("./image/bpPlanLight.png");
  color: #805c34;
}
.bpBg > .bpDialogHide > .bpPlansBg > .bpPlans > .bpPlan > .bpYingyong {
  /*应用中*/
  left: 0.5%;
  top: 0%;
  background-image: url("./image/bpYingyong.png");
  background-size: 100% 100%;
  height: 40%;
  width: 45%;
}
.bpBg > .bpDialogHide > .bpPlansBg > .bpPlans > .bpPlan > .bpPlanText {
  /*每个方案文本*/
  text-align: center;
  width: 100%;
  display: inline-block;
  font-family: "yuanli";
  font-size: 19px;
  transform: translateY(-50%);
  top: 50%;
  font-weight: 550;
}
.bpBg > .bpDialogHide > .bpPlansBg > .bpPlans > .bpPlan > .bpPlanNameChange {
  /*方案改名*/
  background-image: url("./image/bpPlanNameChange.png");
  background-size: 100% 100%;
  right: 5%;
  transform: translateY(-50%);
  top: 50%;
  height: 20px;
  width: 20px;
}
/*第二页  方案设置*/
.planBg {
  /*第二页面大背景*/
  width: 100%;
  height: 100%;
  left: 0px;
  top: 0px;
  z-index: 9;
  background-color: rgb(0, 0, 0, 0.8);
}
.planBg > .planChooseBg {
  /*第二页面小背景图*/
  background-image: url("./image/planChooseBg.png");
  background-size: 100% 100%;
  top: 50%;
  left: 50%;
  height: 410px;
  width: 600px;
  transform: translate(-50%, -50%);
}
.planBg > .planChooseBg > .text {
  /*第二页面顶部文字*/
  left: 50%;
  transform: translateX(-50%);
  top: 2%;
  font-size: 20px;
  color: #e3b88b;
  font-weight: 550;
  text-shadow: none;
  font-family: "yuanli";
}
.planBg > .planChooseBg > .planBigBg {
  /*第二页面大框*/
  width: 99.5%;
  left: 0.4%;
  height: 89.5%;
  top: 8.9%;
  overflow-y: auto;
  overflow-x: hidden;
  display: block;
}
/*以下包括导入方案，删除方案，模式选择的各种样式，其父元素都是基于上面这些来设置的*/

/*模式选择*/
.planBg > .planChooseBg > .planModeBg {
  /*左侧模式底板*/
  background-image: url("./image/bpChoosePackBg.png");
  background-size: 100% 100%;
  top: 9%;
  left: 0.3%;
  height: 89.2%;
  width: 25%;
  overflow-y: auto;
  overflow-x: hidden;
  display: block;
}
.planBg > .planChooseBg > .planModeBg > .planMode {
  /*左侧模式*/
  text-align: center;
  align-items: center;
  font-family: "yuanli";
  color: #805c34;
  position: relative;
  font-weight: 580;
  display: block;
  font-size: 19px;
  height: 9.41%;
  text-shadow: none;
  width: 100%;
  padding-top: 20px;
}
.planBg > .planChooseBg > .planModeBg > .planMode:before {
  /*模式名下划线*/
  content: "";
  background-image: url("./image/bpCharacterPackLine.png");
  line-height: 15;
  background-size: 100% 100%;
  width: 90%;
  height: 0.5px;
  position: absolute;
  bottom: -0.5px;
  transform: translateX(-50%);
  left: 50%;
}
.planBg > .planChooseBg > .planModeBg > .planMode.active {
  /*模式名点击效果*/
  background-image: url("./image/bpCharacterPack.png");
  background-size: 100% 100%;
  color: #805c34;
}
.planBg > .planChooseBg > .planRightBg {
  /*右侧方案底板*/
  width: 75%;
  height: 89.5%;
  top: 9%;
  left: 25%;
}
.planBg > .planChooseBg > .planRightBg > .planModeText {
  /*此模式应用方案文字*/
  top: 5%;
  font-size: 18px;
  color: #805c34;
  text-shadow: none;
  font-family: "yuanli";
  width: 100%;
  position: relative;
  text-align: center;
}
.planBg > .planChooseBg > .planRightBg > .choosePlanBg {
  /*备选方案*/
  height: 85%;
  width: 100%;
  background-color: rgb(0, 0, 0, 0.2);
  bottom: 0%;
  left: 0%;
  overflow-y: auto;
  display: block;
}
.planBg > .planChooseBg > .planRightBg > .choosePlanBg > .choosePlan {
  /*每个方案*/
  background-image: url("./image/bpPlan.png");
  background-size: 100% 100%;
  height: 14%;
  width: 28%;
  margin: 10px;
  position: relative;
  color: #e3b88b;
}
.planBg > .planChooseBg > .planRightBg > .choosePlanBg > .choosePlan:active {
  background-image: url("./image/bpPlanLight.png");
  color: #805c34;
}
.planBg
  > .planChooseBg
  > .planRightBg
  > .choosePlanBg
  > .choosePlan
  > .planYingyong {
  /*应用中*/
  left: 0.5%;
  top: 0%;
  background-image: url("./image/bpYingyong.png");
  background-size: 100% 100%;
  height: 40%;
  width: 45%;
}
.planBg
  > .planChooseBg
  > .planRightBg
  > .choosePlanBg
  > .choosePlan
  > .chooseText {
  /*方案选择文本*/
  text-align: center;
  width: 100%;
  display: inline-block;
  font-family: "yuanli";
  font-size: 19px;
  transform: translateY(-50%);
  top: 50%;
  font-weight: 550;
  text-shadow: none;
}
.planBg > .planChooseBg > .planRightBg > .choosePlanBg > .choosePlan.active {
  /*每个方案点击效果*/
  background-image: url("./image/bpPlanLight.png");
}

/*导入方案和删除方案（通用）*/
.planBg > .planChooseBg > .planBigBg > .planBtn {
  /*按钮*/
  background-image: url("./image/bpPlan.png");
  background-size: 100% 100%;
  position: relative;
  color: #e3b88b;
  height: 15%;
  text-shadow: none;
  width: 25%;
  margin-top: 5%;
  margin-left: 6.25%;
}
.planBg > .planChooseBg > .planBigBg > .planBtn > .text {
  /*按钮文字*/
  text-align: center;
  width: 100%;
  display: inline-block;
  font-family: "yuanli";
  font-size: 19px;
  transform: translateY(-50%);
  top: 50%;
  font-weight: 550;
  text-shadow: none;
}
