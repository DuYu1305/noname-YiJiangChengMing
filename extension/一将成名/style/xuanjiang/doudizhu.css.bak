#arena.decadeUI.choose-character > .dialog#xjk,
#arena.decadeUI.choose-character.dui-mobile > .dialog#xjk {
  width: 100% !important;
  height: 100% !important;
  left: 0px !important;
  top: 0px !important;
  display: block !important;
  z-index: 6;
  position: absolute;
  text-align: center;
  overflow: visible !important;
  overflow-y: visible !important;
  animation: fadenum 1s ease;
}
.xjbackground {
  width: 100% !important;
  height: 100% !important;
  left: 0px !important;
  top: 0px !important;
  display: block !important;
  z-index: 4;
  position: absolute;
}
.topBar {
  background-image: url("../../resource/image/xuanjiang/doudizhu/topBar.png") !important;
  background-size: 100% 100%;
  width: 30%;
  height: 38px;
  left: 35%;
  top: -2%;
  position: absolute;
  color: #957e73;
  font-size: 20px;
  font-family: "yuanli";
  line-height: 33px;
  text-align: center;
  font-weight: bold;
}
.doudizhubutton {
  display: flex;
  width: 50%;
  height: 8%;
  position: absolute;
  bottom: 14%;
  left: 26%;
}

/* 官方势力选择(vcard group_xxx)美化 */
#arena.decadeUI > .dialog .buttons > .button.card[data-card-name^="group_"] {
  width: 120px;
  height: 160px;
  border: none;
  box-shadow: none !important;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name^="group_"] > .image {
  background-size: 100% 100% !important;
  background-repeat: no-repeat;
  background-position: center;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name^="group_"] > .name,
#arena.decadeUI > .dialog .buttons > .button.card[data-card-name^="group_"] > .name2,
#arena.decadeUI > .dialog .buttons > .button.card[data-card-name^="group_"] > .info,
#arena.decadeUI > .dialog .buttons > .button.card[data-card-name^="group_"] > .range,
#arena.decadeUI > .dialog .buttons > .button.card[data-card-name^="group_"] > .gaintag {
  display: none !important;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name="group_wei"] > .image {
  background-image: url("../../resource/image/xuanjiang/group/vcard_wei.png") !important;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name="group_shu"] > .image {
  background-image: url("../../resource/image/xuanjiang/group/vcard_shu.png") !important;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name="group_wu"] > .image {
  background-image: url("../../resource/image/xuanjiang/group/vcard_wu.png") !important;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name="group_qun"] > .image {
  background-image: url("../../resource/image/xuanjiang/group/vcard_qun.png") !important;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name="group_jin"] > .image {
  background-image: url("../../resource/image/xuanjiang/group/vcard_jin.png") !important;
}

#arena.decadeUI > .dialog .buttons > .button.card[data-card-name="group_shen"] > .image {
  background-image: url("../../resource/image/xuanjiang/group/vcard_shen.png") !important;
}
