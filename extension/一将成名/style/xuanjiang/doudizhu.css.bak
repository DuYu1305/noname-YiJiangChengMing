}
.xjhpk
  > .hp:not(.text):not(.actcount):not(.treasure)[data-condition="high"]
  > div:not(.lost):not(.shield) {
  background: url("../../resource/image/xuanjiang/2v2/xinround1.png");

  background-size: 100% 100%;
}
.xjhpk
  > .hp:not(.text):not(.actcount):not(.treasure)[data-condition="mid"]
  > div:not(.lost):not(.shield) {
  background: url("../../resource/image/xuanjiang/2v2/xinround2.png");
  box-shadow: none;
  border: none;
  background-size: 100% 100%;
  transform: scale(1.4);
  -webkit-filter: none;
  border-radius: 0px;
}
.xjhpk
  > .hp:not(.text):not(.actcount):not(.treasure)[data-condition="low"]
  > div:not(.lost):not(.shield) {
  background: url("../../resource/image/xuanjiang/2v2/xinround3.png");
  box-shadow: none;
  border: none;
  background-size: 100% 100%;
  transform: scale(1.4);
  -webkit-filter: none;
  border-radius: 0px;
}
.xjhpk > .hp:not(.text):not(.actcount):not(.treasure) > .lost {
  background: url("../../resource/image/xuanjiang/2v2/xinround4.png");
  box-shadow: none;
  border: none;
  background-size: 100% 100%;
  transform: scale(1.4);
  border-radius: 0px;
}
.xjhpk > .hp:not(.text):not(.actcount):not(.treasure) > .lost,
.xjhpk
  > .hp:not(.text):not(.actcount):not(.treasure)[data-condition="mid"]
  > div:not(.lost),
.xjhpk
  > .hp:not(.text):not(.actcount):not(.treasure)[data-condition="high"]
  > div:not(.lost),
.xjhpk
  > .hp:not(.text):not(.actcount):not(.treasure)[data-condition="low"]
  > div:not(.lost) {
  transform: none !important;
}
/* 可见手牌区域 */
.chakanshoupai {
  background-color: none;
  background-repeat: no-repeat;
  background-color: black; /* 棕色背景 */
  opacity: 0.4;
  width: 40px;
  height: 90px;
  left: -60px;
  bottom: 00px;
  /* padding: 17px 2px 2px 2px;*/
  text-align: center;
  color: #ffffcc;
  text-shadow: -1.3px 0px 2.2px #000, 0px -1.3px 2.2px #000,
    1.3px 0px 2.2px #000, 0px 1.3px 2.2px #000;
  font-family: shousha;
  font-size: 15px;
  font-weight: 900;
  z-index: 8 !important;
}

.dialogshoupai {
  background-position: center;
  background-image: url("../../resource/image/xuanjiang/button/dialog_bg.png");
  background-size: 100% 100% !important;
  background-repeat: no-repeat;
  white-space: normal;
  width: 500px !important;
  height: 223px !important;
  box-shadow: none;
  animation: fadenum 0.5s ease;
  position: absolute;
  z-index: 66;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  zoom: 0.92;
}

.dialogshoupai > .content-container {
  position: absolute;
  width: 445px;
  height: 187px;
  top: 18px;
  left: 22px;
}

.dialogshoupai > .content-container > .caption {
  color: #f1d977;
  text-shadow: -1.3px 0px 2.2px #000, 0px -1.3px 2.2px #000,
    1.3px 0px 2.2px #000, 0px 1.3px 2.2px #000;
  text-align: center;
  top: -9px;
  left: 145px;
  position: absolute;
  font-family: yuanli;
  letter-spacing: 2px;
  font-size: 25px;
}
