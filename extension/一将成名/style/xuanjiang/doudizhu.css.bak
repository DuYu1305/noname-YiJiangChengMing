  text-align: left;
}
.myxj {
  /* --w: 75%; */
  gap: 30px;
  width: 1000px;
  height: 180px;
  display: flex;
  position: relative;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  align-content: center;
  flex-wrap: nowrap;
  left: 50%;
  top: calc(50% - 50px);
  transform: translate(-50%, -50%);
}
.skillwindow {
  background-image: url("../../resource/image/xuanjiang/doudizhu/landlord_general_selected_pannel.png");
  background-size: 100% 100%;
  background-repeat: no-repeat;
  position: absolute;
  width: 520px;
  height: 270px;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 6;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  animation: fadeIn 2s ease-in-out forwards;
  opacity: 0;
}
@keyframes fadeIn {
  0% {
    opacity: 0;
  }
  50% {
    opacity: 0.5;
  }
  100% {
    opacity: 1;
  }
}
.doushenfen {
  width: 25px;
  height: 31px;
  background-size: contain;
  background-repeat: no-repeat;
  position: absolute;
  left: calc(50% - 117px);
