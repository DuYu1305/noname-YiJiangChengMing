.wjbk {
    width: 120%;
    height: 94%;
    left: -20%;
    /* top: 2%; */
    border-radius: 6px 0 0 6px;
}

.wjbk[data-camp="wei"] {
  background: linear-gradient(to top, rgb(35, 83, 123), rgb(15, 35, 68));
}

.wjbk[data-camp="shu"] {
  background: linear-gradient(to top, rgb(153, 28, 34), rgb(57, 12, 17));
}

.wjbk[data-camp="wu"] {
  background: linear-gradient(to top, rgb(29, 114, 29), rgb(34, 42, 27));
}

.wjbk[data-camp="qun"] {
  background: linear-gradient(to top, rgb(154, 148, 122), rgb(74, 72, 57));
}

.wjbk[data-camp="shen"] {
  background: linear-gradient(
    to top,
    rgb(97, 87, 15),
    rgb(65, 50, 9),
    rgb(67, 52, 9)
  );
}

.wjbk[data-camp="jin"] {
  background: linear-gradient(to top, rgb(112, 52, 126), rgb(52, 18, 55));
}

.wjbk[data-camp="ye"] {
  background: linear-gradient(to top, rgb(112, 52, 126), rgb(52, 18, 55));
}

.wjbk[data-camp="key"] {
  background: linear-gradient(
    to top,
    rgb(147, 132, 183),
    rgb(130, 120, 160),
    rgb(120, 115, 154)
  );
}

.wjbk[data-camp="western"] {
  background: linear-gradient(to top, rgb(93, 44, 105), rgb(54, 18, 58));
}

.wjbk[data-camp="daqin"] {
  background: linear-gradient(to top, rgb(100, 100, 100), rgb(0, 0, 0));
}

.wjcampborder {
  display: block;
  left: -14px;
  top: -14px;
  width: 46px;
  height: 0%;
  position: absolute;
  background-size: 100% 100%;
  background-repeat: no-repeat;
  z-index: 1;
}
.xjhpk {
  display: block;
  right: -2%;
  bottom: -3%;
  width: 21%;
  height: 38%;
  background-image: url("../../resource/image/xuanjiang/2v2/border_hp.png");
  pointer-events: none;
  transition-property: transform, opacity, height;
  transition-duration: 0.1s;
  transition-timing-function: linear;
  position: absolute;
  background-repeat: no-repeat;
  background-size: 100% 100%;
  z-index: 1;
}
.xjhpk[hp-value="1"] {
  height: 15%;
}

.xjhpk[hp-value="2"] {
  height: 30%;
}

.xjhpk[hp-value="4"] {
  height: 50%;
}
.xjhpk[hp-value="5"] {
  height: 58%;
}

.xjhpk > .hp {
  display: flex;
  left: 32%;
  width: 50%;
  font-size: 13px;
  flex-direction: column;
  justify-content: flex-end;
  top: 20%;
  position: relative;
  height: 68%;
}
.xjhpk > .hp > div:not(.shield) {
  position: static;
  margin-top: 0px;
  width: 100%;
  margin-left: 0px;
  height: 100%;
  /* line-height: 10px; */
  border: none;
  top: 10px;
}

.highhp {
  background: url("../../resource/image/xuanjiang/2v2/xinround1.png");
  box-shadow: none;
  border: none;
  background-size: contain;
  transform: scale(1.4);
  -webkit-filter: none;
  border-radius: 0px;
  line-height: 7px;
  font-family: "yuanli";
  width: 34%;
  height: 16%;
  position: relative;
  top: 75%;
  left: 9%;
  background-repeat: no-repeat;
}
.highhp > span {
  top: -27px;
  position: relative;
  left: 0px;
  font-size: 11px;
}
.xjshilib {
  font-size: 26px;
  width: 144%;
  height: 0%;
  left: -23%;
  top: -12%;
  display: flex;
  text-align: center;
  align-items: center;
  place-content: center;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center center;
  transition: none 0s ease 0s;
  z-index: 0;
}
.xjtip {
  color: #d0a680;
  font-size: 20px;
  width: 100%;
  height: 8%;
  font-family: yuanli;
  text-align: center;
  line-height: 16px;
