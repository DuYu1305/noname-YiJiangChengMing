			const rightBtnArr = [
				{
					name: "huodongSprite",
					img: "modeActivityBtn_top_btn2_normal.png",
				},
				{
					name: "qifuSprite",
					img: "modeActivityBtn_forever_btn5_normal.png",
					word: "modeActivityBtn_forever_btn5_words.png",
				},
