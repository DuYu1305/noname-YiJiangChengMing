
@keyframes open-dialog {
	from {
		opacity: 0.1;
		transform: scale(0.8);
	}
	to {
		opacity: 1;
		transform: scale(1);
	}
}
/*顺手*/
#choosePlayerCardDialog {
    /*顺手选项框*/
    background-image: url('../image/choosePlayerCard/scdialog.png') !important;
    background-size: 100% 100%;
    width: 1303px;
    height: 390px;
    left: -50px;
    top: 65px;
    display: block !important;
    /* pointer-events: none;*/
    z-index: 8;
    position: absolute;
    text-align: center;
    overflow: visible !important;
    overflow-y: visible !important;
    animation: 0.5s ease 0s 1 normal none running open-dialog;
}
#choosePlayerCardDialog>.choosePlayerCardTitle {
    left: calc(50% - 80px);
    right: calc(50% - 80px);
    /* position: absolute; */
    /* left: 565px; */
    top: 10px;
    text-align: center;
    /* width: 100px; */
    /* height: 50px; */
    overflow: visible !important;
    line-height: 50px;
    font-size: 25px;
    background-image: linear-gradient(180deg,#f0d775 30%,#ab8c31 57%,#b0a04d 67%);
    font-weight: bold;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    white-space: nowrap;
    -webkit-text-stroke: 0px rgba(38,37,34,0.5);
    text-shadow: none;
    filter: drop-shadow(0 0 2px #000) drop-shadow(0 0 2px #000) drop-shadow(0 0 2px #000);
}
#choosePlayerCardDialog[data-pst='e'],
#choosePlayerCardDialog[data-pst='j'],
#choosePlayerCardDialog[data-pst='ej'],
#choosePlayerCardDialog[data-pst='h'] {
    height: 238px;
    top: 110px;
    background-size: cover;
}
#choosePlayerCardDialog[data-pst='ej']>.eTitle,
#choosePlayerCardDialog[data-pst='ej']>.jTitle,
#choosePlayerCardDialog[data-pst='e']>.eTitle,
#choosePlayerCardDialog[data-pst='j']>.jTitle,
#choosePlayerCardDialog[data-pst='h']>.hTitle {
    top: 65px;
    bottom:auto;
}
#choosePlayerCardDialog[data-pst='j']>.jArea,
#choosePlayerCardDialog[data-pst='h']>.hArea {
    top: 65px;
    bottom:auto;
}
#choosePlayerCardDialog[data-pst='e']>.eArea,
#choosePlayerCardDialog[data-pst='ej']>.eArea {
    top: 83px;
    bottom:auto;
}
#choosePlayerCardDialog[data-pst='ej']>.jArea {
    top: 63px;
    bottom:auto;
}
#choosePlayerCardDialog[data-pst='e']>.eTitle,
#choosePlayerCardDialog[data-pst='j']>.jTitle {
    left:25%;
}
#choosePlayerCardDialog[data-pst='e']>.eArea,
#choosePlayerCardDialog[data-pst='j']>.jArea {
    left:27.8%;
}
#choosePlayerCardDialog[data-pst='hj']>.jTitle{
    left:16%;
}
#choosePlayerCardDialog[data-pst='hj']>.jArea {
    left:18.8%;
}
/*顺手框内部大小，缩放到0.9比较符合原本大小*/
/*#choosePlayerCardDialog>div {
    transform: scale(0.9);
    transition: all 0s;
}*/
.dialog#choosePlayerCardDialog>.content-container {
    /*禁止滑动*/
    overflow: hidden !important;
    overflow-y: hidden !important;
    justify-content: flex-start !important;
}
.dialog#choosePlayerCardDialog>.content-container>.content {
    /*禁止滑动*/
    overflow: hidden !important;
    overflow-y: visible !important;
    justify-content: flex-start !important;
}
/*顺拆框的名字*/
.choosePlayerCardTitle {
    left: calc(50% - 80px);
    right: calc(50% - 80px);
    overflow: visible !important;
    width: 200px;
    top: 12px;
    height: 50px;
    text-align: center;
    letter-spacing: 3px!important;
    /* background: linear-gradient(#C8BEB4 1%,#FCF8CC 12%, #F3F0BE,#FEF5A8,#E1D275,#C9B173,#D6CB6F,#A99355,#AC9557,#A38A51,#A38A51,#B29983,#B19786,#B19786,#B19786, #9B8583 ), linear-gradient(to right,#FCF8CC , #AC9557); */
    font-family: yuanli;
    font-size: 35px !important;
    color: white;
    font-weight: normal;
    /* -webkit-background-clip: text; */
    text-shadow: none;
    /* -webkit-text-fill-color: transparent; */
    /* filter: drop-shadow(2px 0 0.5px #2F1809) drop-shadow(-2px 0 1.5px #2F1809) drop-shadow(0 2px 1px #2F1809) drop-shadow(0 -2px 1.5px #2F1809) blur(0.55px) saturate(1.25) contrast(1.25) grayscale(0.08) sepia(0.1); */
}
/*进度条*/
.choosePlayerCard-jindutiao1 {
    display: block;
    position: absolute;
    left:27%;
    bottom:1px;
    width:46%;
    height:20px;
    background-image: url('../image/choosePlayerCard/time.png');
    background-repeat:no-repeat;
    background-size:100% 100%;
    border-radius:20px;
    z-index:7;
    transition:all 0s;
}
.choosePlayerCard-jindutiao2 {
    display: block;
    position: absolute;
    left:0px;
    bottom:0.2px;
    width: 100%;
    height:20px;
    background-image:url('../image/choosePlayerCard/timex.png');
    background-repeat: no-repeat;
    background-size:100% 100%;
    border-radius:20px;
    z-index:8;
    animation: fillProgress 35s linear forwards;
    transition:all 0s;
}
@keyframes fillProgress {
    from {
        background-size: 100% 100%;
    }
    to {
        background-size: 0% 100%;
    }
}
/*底部提升*/
.choosePlayerCardfooterxg {
    display:flex;
    text-align:center;
    top: 350px;
    width:100%;
    left:1%;
    /*background-color:red;*/
    justify-content: center;
    align-items: center;
    color:#BFAF58;
    font-family:'shousha';
    font-size:20px;
    z-index:10;
}
#choosePlayerCardDialog[data-pst='h']>.choosePlayerCardfooterxg,
#choosePlayerCardDialog[data-pst='e']>.choosePlayerCardfooterxg,
#choosePlayerCardDialog[data-pst='j']>.choosePlayerCardfooterxg,
#choosePlayerCardDialog[data-pst='ej']>.choosePlayerCardfooterxg {
    top: 195px;
}
/*手牌区名字*/
.hTitle {
    background-image: url('../image/choosePlayerCard/cebian.png') !important;
    background-size: 100% 100%;
    height: 130px;
    width: 38px;
    writing-mode: tb-rl;
    font-size: 20px;
    left: 16%;
    top: 17%;
    color: #e59738;
    font-family: yuanli;
    justify-content: center;
    align-items: center;
    display: flex;
}
/*手牌区那个长框*/
.hArea {
    background-color: #4e413b;
    background-size:100% 100%;
    background-repeat: no-repeat;
    width: 855px;
    height: 130px;
    left: 19%;
    top: 18%;
    display: flex;
    border-radius: 5px;
    flex-wrap: nowrap;
    overflow-x: visible !important;
    flex-direction: row !important;
    overflow-y: hidden !important;
    justify-content: flex-start !important;
}
/*手牌区的按钮区整体位置*/
.hArea>.buttons {
    margin-top: -5px;
    margin-left: -4.5px;
    width: auto;
    overflow-x: visible !important;
    display: flex;
    flex-wrap: nowrap;
    flex-direction: row !important;
    justify-content: flex-start !important;
}
.hArea>.buttons>.card:not(.selectable) {
    filter: brightness(50%);
}
.eArea>.eAreaCard>.buttons>.card.selectable.selected:before,
.jArea>.jAreaCard>.buttons>.card.selectable.selected:before,
.hArea>.buttons>.card.selectable.selected:before {
    background-image: url('../image/choosePlayerCard/card_select6.png')!important;
    width:122%;
    left:-20%;
    top:-15%;
    height:120%;
    background-size:100% 100%;
    background-repeat: no-repeat;
    filter: saturate(1.3);
}
/*手牌区卡牌的间隔*/
.hArea>.buttons>div:not(:first-child) {
    margin-left: -1.9px;
}
/*装备区名字*/
.eTitle {
    background-image: url('../image/choosePlayerCard/cebian.png') !important;
    background-size: 100% 100%;
    height: 130px;
    width: 38px;
    writing-mode: tb-rl;
    font-size: 20px;
    left: 16%;
    bottom: 11%;
    color: #e59738;
    font-family: yuanli;
    justify-content: center;
    align-items: center;
    display: flex;
}
/*装备区区域*/
.eArea {
    /* background-color: #4e413b;*/
    bottom: 6%;
    left: 18.8%;
    width: 580px;
    height: 130px;
    display: flex;
}
/*装备区每一张独立卡*/
.eAreaCard {
    background-color: #4e413b;
    background-size: 100% 100%;
    margin-left: 5px;
    height: 127px;
    width: 90.5px;
    font-size: 20px;
    top: -15px;
    position: relative;
    font-family: yuanli;
    color: #605f5d;
    text-shadow: 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325;
    justify-content: center;
    align-items: center;
    border-radius: 5px;
    display: flex;
    opacity: 0.95;
}
/*判定区名字*/
.jTitle {
    background-image: url('../image/choosePlayerCard/cebian.png') !important;
    background-size: 100% 100%;
    height: 130px;
    width: 38px;
    writing-mode: tb-rl;
    font-size: 20px;
    left: 59.8%;
    bottom: 11%;
    color: #e59738;
    font-family: yuanli;
    justify-content: center;
    align-items: center;
    display: flex;
}
/*判定区区域*/
.jArea {
    /* background-color: #4e413b;*/
    bottom: 6%;
    left: 62.7%;
    width: 350px;
    height: 150px;
    display: flex;
}
/*判定区独立小卡*/
.jAreaCard {
    background-color: #4e413b;
    background-size: 100% 100%;
    margin-left: 5px;
    height: 127px;
    width: 90.2px;
    font-size: 20px;
    top: 5px;
    border-radius: 5px;
    position: relative;
    font-family: yuanli;
    border-radius: 5px;
    color: #605f5d;
    text-shadow: 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325, 0 0 2px #453325;
    justify-content: center;
    align-items: center;
    display: flex;
    text-align: center;
    opacity: 0.95;
}
/*装备和判定区的div*/
.jAreaCard>div,
.eAreaCard>div {
    margin-top: 10px !important;
    margin-left: -7.5px !important;
    bottom: auto;
    right: auto;
    position: absolute;
}
#arena.choose-character.selecting>#dui-controls>.control.combo-control.lbtn-confirm>div.primary.confirmButton {
    top: -150px !important;
    left:37%;
    position:fixed;
}
#judgeBox.judgeBox {
    background-image: url('../image/choosePlayerCard/scdialog.png');
    background-size: 100% 100%;
    width: 110%;
    height: 250px;
    left: -5%;
    right:-5%;
    top: 10%;
    /* pointer-events: none;*/
    z-index: 8;
    animation: 0.5s ease 0s 1 normal none running open-dialog;
}

/* 选牌框打开时，临时下移确定/取消按钮 */
#arena.choose-player-card > #control,
#arena.choose-player-card > #dui-controls {
    transform: translateY(108px);
}

/* 选牌框打开时，临时关闭十周年UI卡牌选中描边 */
#arena.gain-player-card .dialog#gainPlayerCardDialog .card::before,
.dialog#gainPlayerCardDialog .card::before {
    border-width: 0 !important;
    border-style: none !important;
    border-image: none !important;
    border-image-source: none !important;
    box-shadow: none !important;
	background-image: url('../image/gainPlayerCard/card_select6.png')!important;
    width:126%;
    left:-14%;
    top:-10%;
    height:120%;
    background-size:100% 100%;
    background-repeat: no-repeat;
    filter: saturate(1.3);
}
